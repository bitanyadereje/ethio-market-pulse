<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>FairFind – Ethiopian Marketplace Search</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f5f9ff;
        }
        .fairness-pill {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            font-size: 0.75rem;
            font-weight: 600;
            border-radius: 9999px;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }
        .fairness-fair { background-color: #e6f9ed; color: #0f6e3f; }
        .fairness-overpriced { background-color: #fff3e0; color: #b45f06; }
        .fairness-extreme_overpriced { background-color: #ffe6e5; color: #b91c1c; }
        .fairness-underpriced_good_deal { background-color: #e0f2fe; color: #0c4e6e; }
        .fairness-insufficient_data { background-color: #f0f2f5; color: #5d6f83; }
        .fairness-unknown { background-color: #f0f2f5; color: #5d6f83; }
        .product-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.1);
        }
    </style>
</head>
<body class="bg-white">

    <!-- Header with logo and tagline -->
    <div class="bg-gradient-to-r from-blue-800 to-indigo-800 text-white shadow-lg">
        <div class="container mx-auto px-6 py-8 text-center">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight">FairFind</h1>
            <p class="text-blue-100 mt-2">AI‑powered price fairness for Ethiopian online marketplaces</p>
        </div>
    </div>

    <!-- Main search area (always visible, prominent) -->
    <div class="container mx-auto px-6 py-8">
        <div class="bg-white rounded-2xl shadow-lg border border-blue-100 p-6">
            <form method="GET" action="/" class="space-y-5">
                <!-- Large search input -->
                <div>
                    <label class="block text-blue-800 text-sm font-semibold mb-2">🔍 What are you looking for?</label>
                    <input type="text" name="q" value="<%= locals.query %>" placeholder="e.g., iPhone, shoes, sweater..."
                           class="w-full border border-gray-200 rounded-xl px-5 py-4 text-lg focus:ring-2 focus:ring-blue-300 focus:border-blue-400 transition">
                </div>

                <!-- Filters row -->
                <div class="flex flex-col md:flex-row gap-4">
                    <div class="flex-1">
                        <label class="block text-blue-800 text-sm font-semibold mb-1">📂 Category</label>
                        <select name="category" class="w-full border border-gray-200 rounded-xl px-3 py-2 bg-white focus:ring-2 focus:ring-blue-300">
                            <option value="all" <%= locals.selectedCategory === 'all' ? 'selected' : '' %>>All</option>
                            <% if (locals.categories && locals.categories.length) { %>
                                <% for (var i = 0; i < locals.categories.length; i++) { %>
                                    <option value="<%= locals.categories[i] %>" <%= locals.selectedCategory === locals.categories[i] ? 'selected' : '' %>><%= locals.categories[i] %></option>
                                <% } %>
                            <% } %>
                        </select>
                    </div>
                    <div class="flex-1">
                        <label class="block text-blue-800 text-sm font-semibold mb-1">⚖️ Fairness</label>
                        <select name="fairness" class="w-full border border-gray-200 rounded-xl px-3 py-2 bg-white focus:ring-2 focus:ring-blue-300">
                            <option value="all" <%= locals.selectedFairness === 'all' ? 'selected' : '' %>>All</option>
                            <option value="fair" <%= locals.selectedFairness === 'fair' ? 'selected' : '' %>>🟢 Fair</option>
                            <option value="overpriced" <%= locals.selectedFairness === 'overpriced' ? 'selected' : '' %>>🟡 Overpriced</option>
                            <option value="extreme_overpriced" <%= locals.selectedFairness === 'extreme_overpriced' ? 'selected' : '' %>>🔴 Extreme</option>
                            <option value="underpriced_good_deal" <%= locals.selectedFairness === 'underpriced_good_deal' ? 'selected' : '' %>>💚 Underpriced</option>
                            <option value="insufficient_data" <%= locals.selectedFairness === 'insufficient_data' ? 'selected' : '' %>>⚪ No data</option>
                        </select>
                    </div>
                    <div class="flex-1">
                        <label class="block text-blue-800 text-sm font-semibold mb-1">📊 Sort</label>
                        <select name="sort" class="w-full border border-gray-200 rounded-xl px-3 py-2 bg-white focus:ring-2 focus:ring-blue-300">
                            <option value="recent" <%= locals.selectedSort === 'recent' ? 'selected' : '' %>>Recent</option>
                            <option value="price_asc" <%= locals.selectedSort === 'price_asc' ? 'selected' : '' %>>Price: Low → High</option>
                            <option value="price_desc" <%= locals.selectedSort === 'price_desc' ? 'selected' : '' %>>Price: High → Low</option>
                        </select>
                    </div>
                    <div class="flex items-end">
                        <button type="submit" class="bg-blue-700 hover:bg-blue-800 text-white font-semibold px-8 py-2 rounded-xl transition shadow-md hover:shadow-lg">Search</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Section (only shown if a search has been made) -->
    <div class="container mx-auto px-6 py-8">
        <% if (locals.hasSearch) { %>
            <div class="flex justify-between items-end mb-6 flex-wrap gap-4">
                <h2 class="text-2xl font-bold text-blue-900">
                    📦 Results for <%= locals.query ? `“${locals.query}”` : 'all items' %>
                    <span class="text-base font-normal text-gray-500 ml-2">(<%= locals.products.length %>)</span>
                </h2>
            </div>

            <% if (locals.products.length === 0) { %>
                <div class="bg-white border border-blue-100 rounded-2xl p-12 text-center shadow-sm">
                    <div class="text-5xl mb-4">😕</div>
                    <p class="text-gray-600 text-lg">No products found. Try a different search term or remove filters.</p>
                </div>
            <% } else { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% for (var i = 0; i < locals.products.length; i++) { 
                        var product = locals.products[i]; %>
                        <div class="product-card bg-white rounded-2xl overflow-hidden shadow-md border border-blue-50 transition-all">
                            <div class="p-5">
                                <div class="flex justify-between items-start gap-3">
                                    <h3 class="text-lg font-bold text-gray-800 line-clamp-2">
                                        <%= product.item_name ? product.item_name : 'Unnamed product' %>
                                    </h3>
                                    <span class="fairness-pill fairness-<%= product.fairness_status || 'unknown' %> flex-shrink-0">
                                        <%= product.fairness_status ? product.fairness_status.replace(/_/g, ' ') : 'unknown' %>
                                    </span>
                                </div>
                                <div class="mt-3">
                                    <span class="text-2xl font-bold text-blue-700">
                                        <%= product.price ? product.price.toLocaleString() : '?' %>
                                    </span>
                                    <span class="text-gray-500 ml-1"><%= product.currency || 'ETB' %></span>
                                </div>
                                <div class="mt-3 space-y-1 text-sm text-gray-600">
                                    <% if (product.condition) { %>
                                        <p>📌 Condition: <span class="font-medium"><%= product.condition %></span></p>
                                    <% } %>
                                    <% if (product.location) { %>
                                        <p>📍 Location: <%= product.location %></p>
                                    <% } %>
                                    <% if (product.contact_info) { %>
                                        <p>📞 Contact: <%= product.contact_info %></p>
                                    <% } %>
                                    <% if (product.category) { %>
                                        <p class="text-xs text-blue-600 bg-blue-50 inline-block px-2 py-0.5 rounded-full mt-2">🏷️ <%= product.category %></p>
                                    <% } %>
                                </div>
                                <div class="mt-4 pt-3 border-t border-gray-100">
                                    <% if (product.message_url) { %>
                                        <a href="<%= product.message_url %>" target="_blank" class="text-blue-700 hover:text-blue-900 text-sm font-semibold inline-flex items-center gap-1 transition">
                                            🔗 View original post <span>→</span>
                                        </a>
                                    <% } else { %>
                                        <span class="text-gray-400 text-sm">🔗 No link available</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        <% } else { %>
            <!-- Clean landing state: no results, just a subtle prompt -->
            <div class="bg-white/60 backdrop-blur-sm rounded-2xl p-12 text-center shadow-sm border border-blue-100 mt-4">
                <div class="text-6xl mb-4">🔍</div>
                <p class="text-gray-600 text-lg">Enter a search term above to find products with AI fairness scores.</p>
                <p class="text-gray-500 text-sm mt-2">Example: "shoes", "iPhone", "clothing"</p>
            </div>
        <% } %>
    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-blue-100 py-8 mt-12">
        <div class="container mx-auto px-6 text-center text-gray-500 text-sm">
            <p>FairFind – AI‑powered price transparency for Ethiopian marketplaces.</p>
            <p class="mt-1">🤖 Try our Telegram bot: <a href="https://t.me/FairFindBot" target="_blank" class="text-blue-600 hover:underline">@FairFindBot</a></p>
            <p class="mt-2 text-xs text-gray-400">© 2026 FairFind</p>
        </div>
    </footer>
</body>
</html>